<Window x:Class="HermesMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hermes Monitor"
        Height="740" Width="1100"
        MinHeight="520" MinWidth="800"
        WindowStyle="None"
        Background="#FFF5F2EB"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Color x:Key="Bg">#FFF5F2EB</Color>
        <Color x:Key="BgDark">#FFECE8DD</Color>
        <Color x:Key="Green">#FF5B7B5E</Color>
        <Color x:Key="GreenLight">#FF7A9A7D</Color>
        <Color x:Key="GreenDark">#FF3D5B40</Color>
        <Color x:Key="GreenBg">#FFE4EDE0</Color>
        <Color x:Key="GreenBgLight">#FFEFF5EC</Color>
        <Color x:Key="Orange">#FFC9653B</Color>
        <Color x:Key="OrangeLight">#FFE07A4E</Color>
        <Color x:Key="OrangeBg">#FFF7EDE0</Color>
        <Color x:Key="TextPri">#FF2C2C2A</Color>
        <Color x:Key="TextSec">#FF6B6A66</Color>
        <Color x:Key="TextDim">#FF9C9A94</Color>
        <Color x:Key="CardBg">#FFFAF8F4</Color>
        <Color x:Key="CardBorder">#FFE6E0D4</Color>
        <Color x:Key="Shadow">#1A000000</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource Bg}"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="GreenLightBrush" Color="{StaticResource GreenLight}"/>
        <SolidColorBrush x:Key="GreenDarkBrush" Color="{StaticResource GreenDark}"/>
        <SolidColorBrush x:Key="GreenBgBrush" Color="{StaticResource GreenBg}"/>
        <SolidColorBrush x:Key="GreenBgLightBrush" Color="{StaticResource GreenBgLight}"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource Orange}"/>
        <SolidColorBrush x:Key="OrangeLightBrush" Color="{StaticResource OrangeLight}"/>
        <SolidColorBrush x:Key="OrangeBgBrush" Color="{StaticResource OrangeBg}"/>
        <SolidColorBrush x:Key="TextPriBrush" Color="{StaticResource TextPri}"/>
        <SolidColorBrush x:Key="TextSecBrush" Color="{StaticResource TextSec}"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>
    </Window.Resources>
    <Border CornerRadius="0" Background="{StaticResource BgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>
            <!-- Title Bar -->
            <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="24,0,20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource GreenBrush}" CornerRadius="3" Width="28" Height="28">
                            <TextBlock Text="H" FontWeight="700" Foreground="#FFF5F2EB" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="  Hermes Monitor" FontSize="17" FontWeight="500" VerticalAlignment="Center" Foreground="{StaticResource TextPriBrush}" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Name="ThemeBtn" CornerRadius="4" Width="28" Height="28" Cursor="Hand" Margin="0,0,8,0" MouseLeftButtonDown="ThemeToggle_Click" MouseEnter="BtnEnter" MouseLeave="BtnLeave" Background="Transparent">
                            <TextBlock Name="ThemeIcon" Text="🌙" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Name="ExportBtn" Text="📥" FontSize="16" Foreground="{StaticResource TextSecBrush}" Cursor="Hand" Margin="0,0,12,0" MouseLeftButtonDown="Export_Click" MouseEnter="BtnEnter" MouseLeave="BtnLeave"/>
                        <TextBlock Name="RefreshBtn" Text="↻" FontSize="18" Foreground="{StaticResource TextSecBrush}" Cursor="Hand" Margin="0,0,12,0" MouseLeftButtonDown="Refresh_Click" MouseEnter="BtnEnter" MouseLeave="BtnLeave"/>
                        <TextBlock Name="CloseBtn" Text="✕" FontSize="16" Foreground="{StaticResource TextSecBrush}" Cursor="Hand" MouseLeftButtonDown="Close_Click" MouseEnter="BtnEnter" MouseLeave="BtnLeave"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Stats Bar -->
            <WrapPanel Grid.Row="1" Margin="24,10,24,6" Name="StatsPanel">
                <Border CornerRadius="8" Padding="14,0" Height="34" Margin="0,0,10,0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="MCP" FontSize="12" FontWeight="500" VerticalAlignment="Center" Foreground="{StaticResource TextPriBrush}"/>
                        <Border Background="{StaticResource GreenBgBrush}" CornerRadius="6" Padding="8,1,8,1" Margin="8,0,0,0">
                            <TextBlock Name="StatMCP" Text="0" FontSize="13" FontWeight="700" Foreground="{StaticResource GreenDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border CornerRadius="8" Padding="14,0" Height="34" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenLightBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Skills" FontSize="12" FontWeight="500" VerticalAlignment="Center" Foreground="{StaticResource TextPriBrush}"/>
                        <Border Background="{StaticResource GreenBgBrush}" CornerRadius="6" Padding="8,1,8,1" Margin="8,0,0,0">
                            <TextBlock Name="StatSkills" Text="0" FontSize="13" FontWeight="700" Foreground="{StaticResource GreenDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border CornerRadius="8" Padding="14,0" Height="34" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border CornerRadius="4" Padding="6,0,6,0" Background="Transparent" Width="140">
                            <TextBox Name="SearchBox" FontSize="12" Foreground="{StaticResource TextSecBrush}" BorderThickness="0" Background="Transparent" Text="" VerticalAlignment="Center" TextChanged="Search_TextChanged"/>
                        </Border>
                    </StackPanel>
                </Border>
            </WrapPanel>
            <!-- Agent Framework Info Banner -->
            <Border Grid.Row="2" Background="{StaticResource GreenBgBrush}" CornerRadius="8" Margin="24,0,24,6" Padding="12,6" BorderBrush="{StaticResource GreenLightBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🤖" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Name="AgentInfoText" Text="Supports Claude Code · Codex · Cursor · Windsurf · OpenCode · Gemini · Copilot + project-level MCP" FontSize="11" Foreground="{StaticResource GreenDarkBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- Tabs -->
            <Border Grid.Row="3" Background="{StaticResource CardBgBrush}" CornerRadius="10" Margin="24,0,24,8" Padding="4" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border Name="MCPTabBg" CornerRadius="8" Padding="22,0" Background="{StaticResource GreenBrush}" Height="36" Cursor="Hand" Margin="0,0,4,0" MouseLeftButtonDown="TabMCP_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Name="MCPTabText" Text="  MCP" FontSize="13" FontWeight="600" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <Border Background="#30FFFFFF" CornerRadius="6" Padding="6,1,6,1">
                                <TextBlock Name="MCPTabBadge" Text="0" FontSize="10" FontWeight="700" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Name="SkillsTabBg" CornerRadius="8" Padding="22,0" Background="Transparent" Height="36" Cursor="Hand" MouseLeftButtonDown="TabSkills_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🧩" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Name="SkillsTabText" Text="  Skills" FontSize="13" FontWeight="500" Foreground="{StaticResource TextSecBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource GreenBgLightBrush}" CornerRadius="6" Padding="6,1,6,1">
                                <TextBlock Name="SkillsTabBadge" Text="0" FontSize="10" FontWeight="600" Foreground="{StaticResource GreenDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            <!-- Content -->
            <Grid Grid.Row="4" Margin="24,0,24,8">
                <ScrollViewer Name="ScrollerMCP" VerticalScrollBarVisibility="Hidden" Background="Transparent" BorderThickness="0">
                    <StackPanel Name="MCPList"/>
                </ScrollViewer>
                <ScrollViewer Name="ScrollerSkills" VerticalScrollBarVisibility="Hidden" Visibility="Collapsed" Background="Transparent" BorderThickness="0">
                    <StackPanel Name="SkillsList"/>
                </ScrollViewer>
            </Grid>
            <!-- Status Bar -->
            <Border Grid.Row="5" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="24,0,24,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Name="LiveDot" Width="6" Height="6" Fill="{StaticResource GreenBrush}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7"/>
                        <TextBlock Text="Live" FontSize="11" Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Name="LastUpdateText" Text="Just now" FontSize="11" Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
